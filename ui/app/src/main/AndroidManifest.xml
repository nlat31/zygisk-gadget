<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      WARNING: QUERY_ALL_PACKAGES is restricted for Play Store apps.
      This sample is intended for local/debug usage (e.g., Magisk companion UI).
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <!--
      Android 11+ package visibility:
      Without <queries> (or QUERY_ALL_PACKAGES), getInstalledApplications() may return almost nothing.
      This declares visibility for launchable (user-facing) apps.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SampleSettings">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>

